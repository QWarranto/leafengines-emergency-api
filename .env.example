# LeafEngines Environment Variables
# Copy to .env for local development
# Add to Render dashboard for production

# ===== STRIPE CONFIGURATION =====
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# Get from: Stripe Dashboard → Developers → Webhooks
# After creating webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===== DATABASE (PostgreSQL) =====
# Render provides this automatically when you add PostgreSQL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://your_database_url_here

# ===== APPLICATION SECURITY =====
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=generate_a_random_string_here

# For internal usage tracking
LEAFENGINES_STATS_KEY=stats_tracking_key_here

# ===== FOUNDER PRICING =====
# First 100 customers get lifetime pricing
FOUNDER_CUTOFF=100

# Launch date for founder pricing window (30 days from launch)
FOUNDER_LAUNCH_DATE=2026-04-12

# ===== API RATE LIMITS =====
# Daily call limits per tier
FREE_TIER_DAILY_LIMIT=100
STARTER_TIER_DAILY_LIMIT=10000
PRO_TIER_DAILY_LIMIT=50000
ENTERPRISE_TIER_DAILY_LIMIT=500000

# ===== EMAIL CONFIGURATION (Optional) =====
# For sending welcome emails with API keys
# EMAIL_SERVICE=sendgrid  # or smtp, mailgun, etc.
# EMAIL_API_KEY=your_email_service_key
# FROM_EMAIL=noreply@soilsidekickpro.com

# ===== MONITORING =====
# For error tracking and performance monitoring
# SENTRY_DSN=your_sentry_dsn_here
# LOG_LEVEL=INFO

# ===== COMPOSIO SPECIAL HANDLING =====
# Retroactive setup for April 3 enterprise customer
COMPOSIO_EMAIL=integrations@composio.dev
COMPOSIO_FOUNDER_NUMBER=1